{
  "version": 2,
  "outputDirectory": ".next",
  "regions": ["ams1"],
  "functions": {
    "**/*.func": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
